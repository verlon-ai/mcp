{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "ai.verlon/mcp",
  "title": "Verlon AI MCP",
  "description": "Inspect and manage Verlon AI gates, logs, recommendations, and experiments from any MCP client.",
  "version": "0.3.2",
  "icons": [
    {
      "src": "https://verlon.ai/branding/icon/icon-512.png",
      "mimeType": "image/png",
      "sizes": ["512x512"]
    }
  ],
  "repository": {
    "url": "https://github.com/verlon-ai/mcp",
    "source": "github"
  },
  "websiteUrl": "https://docs.verlon.ai/integrations/mcp",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@verlon-ai/mcp",
      "version": "0.3.2",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "VERLON_API_KEY",
          "description": "Verlon API key (sk-vrln-...). Generate at https://verlon.ai/dashboard/settings/keys.",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "VERLON_BASE_URL",
          "description": "Override the Verlon API base URL. Defaults to https://api.verlon.ai.",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
